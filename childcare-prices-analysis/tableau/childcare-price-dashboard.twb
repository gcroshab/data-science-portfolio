              <zone h='91250' id='6' type-v2='layout-basic' w='98400' x='800' y='7750'>
                <zone h='45624' id='8' is-centered='0' is-scaled='1' param='/Users/roshan/Downloads/Top 10 states.jpg' type-v2='bitmap' w='49200' x='800' y='7750'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone h='91250' id='9' is-centered='0' is-scaled='1' param='/Users/roshan/Downloads/Distribution of price.jpg' type-v2='bitmap' w='49200' x='50000' y='7750'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
