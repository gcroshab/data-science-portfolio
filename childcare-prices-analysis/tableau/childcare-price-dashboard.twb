                <zone h='45626' id='10' is-centered='0' is-scaled='1' param='/Users/roshan/Downloads/Income vs price.jpg' type-v2='bitmap' w='49200' x='800' y='53374'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
